<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Actividad de Logaritmos</title>
<style>
  * { box-sizing: border-box; margin: 0; padding: 0; }
  body { font-family: system-ui, sans-serif; background: #f9f9f7; min-height: 100vh; display: flex; align-items: flex-start; justify-content: center; padding: 2rem 1rem; }
  .app { width: 100%; max-width: 640px; }
  h1 { font-size: 22px; font-weight: 500; margin-bottom: 1.5rem; color: #1a1a1a; }
  .header { display: flex; align-items: center; gap: 12px; margin-bottom: 1.5rem; }
  .progress-bar-bg { flex: 1; height: 8px; background: #e0e0d8; border-radius: 99px; overflow: hidden; }
  .progress-bar-fill { height: 100%; background: #1D9E75; border-radius: 99px; transition: width 0.4s ease; }
  .lives { font-size: 14px; color: #666; font-weight: 500; }
  .card { background: white; border: 0.5px solid #e0e0d8; border-radius: 12px; padding: 1.5rem; margin-bottom: 1rem; }
  .tag { display: inline-block; font-size: 12px; font-weight: 500; background: #E1F5EE; color: #0F6E56; padding: 4px 10px; border-radius: 99px; margin-bottom: 1rem; }
  .question-text { font-size: 17px; line-height: 1.8; color: #1a1a1a; }
  .blank { display: inline-block; min-width: 80px; border: none; border-bottom: 2.5px solid #1D9E75; font-size: 17px; font-family: inherit; color: #1a1a1a; background: transparent; text-align: center; padding: 0 4px 2px; outline: none; transition: border-color 0.2s; }
  .blank:focus { border-bottom-color: #0F6E56; }
  .blank.correct { border-bottom-color: #1D9E75; color: #0F6E56; }
  .blank.wrong { border-bottom-color: #E24B4A; color: #A32D2D; animation: shake 0.3s; }
  @keyframes shake { 0%,100%{transform:translateX(0)} 25%{transform:translateX(-4px)} 75%{transform:translateX(4px)} }
  .hint { font-size: 13px; color: #888; margin-top: 0.75rem; font-style: italic; }
  .feedback-bar { border-radius: 12px; padding: 1rem 1.25rem; margin-bottom: 1rem; font-size: 14px; font-weight: 500; display: none; }
  .feedback-bar.correct { background: #E1F5EE; color: #0F6E56; display: block; }
  .feedback-bar.wrong { background: #FCEBEB; color: #A32D2D; display: block; }
  .btn { width: 100%; padding: 14px; border-radius: 12px; font-size: 16px; font-weight: 500; cursor: pointer; border: none; transition: all 0.15s; margin-bottom: 0.5rem; }
  .btn-check { background: #1D9E75; color: white; }
  .btn-check:hover { background: #0F6E56; }
  .btn-check:disabled { background: #e0e0d8; color: #aaa; cursor: default; }
  .btn-next { background: white; border: 0.5px solid #ccc; color: #1a1a1a; display: none; }
  .btn-next:hover { background: #f5f5f0; }
  .counter { font-size: 13px; color: #888; text-align: center; margin-bottom: 1rem; }
  .finish { text-align: center; padding: 2rem 1rem; }
  .finish-icon { font-size: 48px; margin-bottom: 1rem; }
  .finish h2 { font-size: 22px; font-weight: 500; margin-bottom: 0.5rem; color: #1a1a1a; }
  .finish p { color: #666; margin-bottom: 1.5rem; }
  .score-big { font-size: 36px; font-weight: 500; color: #1D9E75; }
  .star-gold { color: #EF9F27; font-size: 20px; }
  .star-empty { color: #ddd; font-size: 20px; }
</style>
</head>
<body>
<div class="app">
  <h1>📐 Actividad de Logaritmos</h1>

  <div class="header">
    <div class="progress-bar-bg"><div class="progress-bar-fill" id="progress" style="width:0%"></div></div>
    <div class="lives" id="lives">❤️❤️❤️</div>
  </div>

  <div id="activity">
    <div class="counter" id="counter">Pregunta 1 de 7</div>
    <div class="card" id="card">
      <div class="tag" id="tag"></div>
      <div class="question-text" id="question"></div>
      <div class="hint" id="hint"></div>
    </div>
    <div class="feedback-bar" id="feedback"></div>
    <button class="btn btn-check" id="btn-check" disabled onclick="checkAnswer()">Comprobar</button>
    <button class="btn btn-next" id="btn-next" onclick="nextQuestion()">Siguiente →</button>
  </div>

  <div id="finish" style="display:none" class="finish">
    <div class="finish-icon">🎉</div>
    <div class="score-big" id="score-display"></div>
    <div id="stars" style="margin:0.5rem 0 1rem;"></div>
    <h2>¡Actividad completada!</h2>
    <p id="finish-msg"></p>
    <button class="btn btn-check" onclick="restart()">Reintentar ↺</button>
  </div>
</div>

<script>
const questions = [
  {
    tag: "Definición",
    template: ["Si ", " = 8, entonces log₂(8) = ", ""],
    blanks: ["2³", "3"],
    hint: "Recuerda: logₐ(b) = c  significa que  aᶜ = b",
    explanation: "2³ = 8, por lo tanto log₂(8) = 3"
  },
  {
    tag: "Base 10",
    template: ["log₁₀(1000) = ", " porque 10", " = 1000"],
    blanks: ["3", "³"],
    hint: "¿Cuántas veces multiplicas 10 por sí mismo para obtener 1000?",
    explanation: "10³ = 1000, así que log₁₀(1000) = 3"
  },
  {
    tag: "Logaritmo natural",
    template: ["El logaritmo natural se escribe como ", "(x) y usa la base ", ""],
    blanks: ["ln", "e"],
    hint: "e ≈ 2.718... es el número de Euler",
    explanation: "ln(x) = logₑ(x), con base e ≈ 2.718"
  },
  {
    tag: "Propiedad — producto",
    template: ["log(A · B) = log(A) ", " log(B)"],
    blanks: ["+"],
    hint: "El logaritmo del producto se convierte en...",
    explanation: "El logaritmo de un producto es la suma de logaritmos"
  },
  {
    tag: "Propiedad — cociente",
    template: ["log(A / B) = log(A) ", " log(B)"],
    blanks: ["−"],
    hint: "La división dentro del logaritmo se convierte en...",
    explanation: "El logaritmo de un cociente es la resta de logaritmos"
  },
  {
    tag: "Propiedad — potencia",
    template: ["log(xⁿ) = ", " · log(x)"],
    blanks: ["n"],
    hint: "El exponente puede salir del logaritmo multiplicando",
    explanation: "El exponente pasa a multiplicar fuera del logaritmo"
  },
  {
    tag: "Valor especial",
    template: ["log", "(1) = ", " para cualquier base válida"],
    blanks: ["ₐ", "0"],
    hint: "¿Qué potencia de cualquier número da como resultado 1?",
    explanation: "a⁰ = 1 siempre, por eso logₐ(1) = 0"
  }
];

let current = 0, lives = 3, score = 0, checked = false;

function renderQuestion() {
  const q = questions[current];
  document.getElementById('counter').textContent = `Pregunta ${current+1} de ${questions.length}`;
  document.getElementById('tag').textContent = q.tag;
  document.getElementById('hint').textContent = '💡 ' + q.hint;
  document.getElementById('progress').style.width = (current / questions.length * 100) + '%';
  document.getElementById('feedback').className = 'feedback-bar';
  document.getElementById('btn-check').style.display = 'block';
  document.getElementById('btn-check').disabled = true;
  document.getElementById('btn-next').style.display = 'none';
  checked = false;

  let html = '';
  q.template.forEach((part, i) => {
    html += part;
    if (i < q.blanks.length) {
      const w = Math.max(60, q.blanks[i].length * 18 + 24);
      html += `<input class="blank" id="b${i}" data-index="${i}" style="width:${w}px" autocomplete="off" spellcheck="false" oninput="onInput()" onkeydown="onKey(event)">`;
    }
  });
  document.getElementById('question').innerHTML = html;
  document.querySelector('#b0')?.focus();
}

function onInput() {
  const allFilled = questions[current].blanks.every((_, i) => document.getElementById('b'+i)?.value.trim() !== '');
  document.getElementById('btn-check').disabled = !allFilled;
}

function onKey(e) {
  if (e.key === 'Enter' && !document.getElementById('btn-check').disabled && !checked) checkAnswer();
  else if (e.key === 'Enter' && checked) nextQuestion();
}

function normalize(s) {
  return s.trim().toLowerCase().replace(/\s+/g,'');
}

function checkAnswer() {
  if (checked) return;
  checked = true;
  const q = questions[current];
  let allCorrect = true;
  q.blanks.forEach((ans, i) => {
    const inp = document.getElementById('b'+i);
    if (normalize(inp.value) === normalize(ans)) {
      inp.classList.add('correct');
      inp.value = ans;
    } else {
      inp.classList.add('wrong');
      allCorrect = false;
    }
  });

  const fb = document.getElementById('feedback');
  if (allCorrect) {
    score++;
    fb.className = 'feedback-bar correct';
    fb.textContent = '✓ ¡Correcto! ' + q.explanation;
  } else {
    lives--;
    updateLives();
    fb.className = 'feedback-bar wrong';
    fb.textContent = '✗ Respuesta correcta: ' + q.explanation;
    q.blanks.forEach((ans, i) => { document.getElementById('b'+i).value = ans; });
  }

  document.getElementById('btn-check').style.display = 'none';
  document.getElementById('btn-next').style.display = 'block';
  if (lives <= 0 && current < questions.length - 1) {
    document.getElementById('btn-next').onclick = showFinish;
  }
}

function updateLives() {
  const icons = ['💀','❤️','❤️❤️','❤️❤️❤️'];
  document.getElementById('lives').textContent = icons[Math.max(0,lives)];
}

function nextQuestion() {
  if (current >= questions.length - 1 || lives <= 0) { showFinish(); return; }
  current++;
  renderQuestion();
}

function showFinish() {
  document.getElementById('activity').style.display = 'none';
  document.getElementById('finish').style.display = 'block';
  document.getElementById('progress').style.width = '100%';
  const pct = score / questions.length;
  document.getElementById('score-display').textContent = score + ' / ' + questions.length;
  const starCount = pct >= 0.85 ? 3 : pct >= 0.57 ? 2 : 1;
  document.getElementById('stars').innerHTML =
    Array(starCount).fill('<span class="star-gold">★</span>').join('') +
    Array(3-starCount).fill('<span class="star-empty">★</span>').join('');
  const msgs = ['Sigue practicando, ¡tú puedes! 💪','¡Buen trabajo! Ya dominas los conceptos básicos. 📚','¡Excelente! Eres un maestro de los logaritmos. 🏆'];
  document.getElementById('finish-msg').textContent = msgs[starCount-1];
}

function restart() {
  current = 0; lives = 3; score = 0; checked = false;
  updateLives();
  document.getElementById('activity').style.display = 'block';
  document.getElementById('finish').style.display = 'none';
  renderQuestion();
}

renderQuestion();
</script>
</body>
</html>
